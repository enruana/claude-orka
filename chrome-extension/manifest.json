{
  "manifest_version": 3,
  "name": "Orka Tab Groups",
  "description": "Auto-groups Orka tabs by project with color coding",
  "version": "1.0.0",
  "permissions": ["tabs", "tabGroups"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
